{
  "expo": {
    "name": "Confraria",
    "slug": "app-confraria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Icones_IMG.png",
    "scheme": "appconfraria",
    "userInterfaceStyle": "automatic",
    "ios": {
      "associatedDomains": [
        "applinks:confraria-web.vercel.app"
      ],
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.caiquegl22.appconfraria",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Icones_IMG.png",
        "backgroundImage": "./assets/images/Icones_IMG.png",
        "monochromeImage": "./assets/images/Icones_IMG.png"
      },
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "host": "confraria-web.vercel.app",
              "pathPrefix": "/events",
              "scheme": "https"
            }
          ]
        }
      ],
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": true,
      "package": "com.caiquegl22.appconfraria",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "checkAutomatically": "NEVER",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/05d39947-b293-4a74-a806-4d3828cd0c63"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o Confraria acesse sua câmera para criar postagens.",
          "microphonePermission": "Permita que o Confraria acesse seu microfone para gravar vídeos nos stories."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permita que o Confraria acesse sua câmera para criar postagens.",
          "photosPermission": "Permita que o Confraria acesse suas fotos para criar postagens."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#C8F763",
          "image": "./assets/images/Splash_Screen.png",
          "resizeMode": "contain"
        }
      ],
      "expo-notifications",
      "expo-video",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Confraria usa sua localização para mostrar eventos perto de você."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05d39947-b293-4a74-a806-4d3828cd0c63"
      }
    },
    "owner": "caiquegl-2-2"
  }
}
