{
  "expo": {
    "name": "app-confraria",
    "slug": "app-confraria",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "appconfraria",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "package": "com.caiquegl22.appconfraria"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "checkAutomatically": "NEVER",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/05d39947-b293-4a74-a806-4d3828cd0c63"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o Confraria acesse sua câmera para criar postagens."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Permita que o Confraria acesse sua câmera para criar postagens.",
          "photosPermission": "Permita que o Confraria acesse suas fotos para criar postagens."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05d39947-b293-4a74-a806-4d3828cd0c63"
      }
    },
    "owner": "caiquegl-2-2"
  }
}
